# Cekura OpenAPI MCP Server Configuration

# OPTIONAL: Base URL of the Cekura API
# Default: https://api.cekura.ai (production)
# Uncomment to override (e.g., for staging/dev environments)
CEKURA_BASE_URL=https://api.cekura.ai

# OPTIONAL: Filter tools by tags (comma-separated)
# Leave empty to use whitelist from documented_apis.json (recommended)
CEKURA_FILTER_TAGS=

# OPTIONAL: Exclude specific operations (comma-separated operation IDs)
# Leave empty to use whitelist from documented_apis.json (recommended)
CEKURA_EXCLUDE_OPERATIONS=

# OPTIONAL: Maximum number of tools to register (for testing only)
# Leave empty for no limit - whitelist determines registered tools
CEKURA_MAX_TOOLS=

# OPTIONAL: Expose the `projects_destroy` tool.
# Default: false — the tool is NOT registered because its blast radius
# cascades to all agents, scenarios, metrics, and results in the project.
# Set to true only if you have an explicit operational need for project deletion via MCP.
CEKURA_EXPOSE_PROJECT_DESTROY=false

# OPTIONAL: Extra tool names to block from registration (comma-separated).
# Applied on top of the default-dangerous list. Example: CEKURA_BLOCKED_TOOLS=end_calls_2,call_logs_destroy
CEKURA_BLOCKED_TOOLS=

# OPTIONAL: Maximum number of request-body examples surfaced per tool from the
# backend's drf-spectacular @extend_schema(examples=[...]) blocks. Default: 2.
# Set to 0 to suppress openapi-sourced examples entirely (overlay example_request
# fallback still applies). Per-tool overrides live in tool_overlays.json as
# `max_examples: N` or `example_names: ["..."]`.
CEKURA_MAX_EXAMPLES_PER_TOOL=2

# NOTE: API keys are REQUIRED via X-CEKURA-API-KEY header when connecting:
# claude mcp add cekura-api http://localhost:8001/mcp --transport http \
#   --header "X-CEKURA-API-KEY:your_api_key_here"

# ---- OAuth discovery settings (required for Claude.ai web connector support) ----

# Public URL of the backend OAuth authorization server.
# Handles /user/oauth/mcp/authorize, /token, /revoke endpoints.
# Default: https://api.cekura.ai (production)
MCP_ISSUER_URL=https://api.cekura.ai

# Public URL of this MCP server — used in /.well-known/oauth-protected-resource.
# Default: https://mcp.cekura.ai (production)
MCP_SERVER_URL=https://api.cekura.ai/mcp

# OPTIONAL: Allow clients to override the backend URL via X-CEKURA-BASE-URL header.
# NEVER enable in production — SSRF risk. For local dev/staging only.
ALLOW_BASE_URL_OVERRIDE=

# REQUIRED for /mcp/monitoring/sessions: the Cekura agent ID under which Claude
# Code session transcripts are ingested as CallLogs via the observe endpoint.
CEKURA_OBSERVE_AGENT_ID=

# OPTIONAL for /mcp/monitoring/sessions: API key used to authenticate the
# server's POST to /observability/v1/observe/. Falls back to CEKURA_API_KEY
# if unset.
CEKURA_OBSERVE_API_KEY=

# AWS Secrets Manager — if set, all other env vars are loaded from this secret at startup.
# AWS_SECRET_NAME=arn:aws:secretsmanager:us-west-1:891377126026:secret:prod-mcp-secrets-LPkmSv
