{
  "family": "mcp-server",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::891377126026:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::891377126026:role/BackendECSRole",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "volumes": [],
  "placementConstraints": [],
  "containerDefinitions": [
    {
      "name": "mcp-server",
      "image": "891377126026.dkr.ecr.us-west-1.amazonaws.com/cekura/mcp-server:<IMAGE_TAG>",
      "essential": true,
      "portMappings": [
        {
          "name": "mcp-server-8001-port",
          "containerPort": 8001,
          "hostPort": 8001,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "environment": [
        {
          "name": "CEKURA_BASE_URL",
          "value": "https://api.cekura.ai"
        },
        {
          "name": "CEKURA_OPENAPI_SPEC_PATH",
          "value": "/app/openapi.json"
        },
        {
          "name": "AWS_SECRET_NAME",
          "value": "arn:aws:secretsmanager:us-west-1:891377126026:secret:prod-mcp-secrets-LPkmSv"
        }
      ],
      "secrets": [],
      "logConfiguration": {
        "logDriver": "awsfirelens",
        "options": {
          "Name": "datadog",
          "Host": "http-intake.logs.us5.datadoghq.com",
          "TLS": "on",
          "dd_service": "mcp-server",
          "dd_source": "mcp-server",
          "dd_message_key": "log",
          "dd_tags": "env:prod,version:<IMAGE_TAG>",
          "provider": "ecs"
        },
        "secretOptions": [
          {
            "name": "apikey",
            "valueFrom": "arn:aws:secretsmanager:us-west-1:891377126026:secret:datadog-api-key-N1eR8O"
          }
        ]
      }
    },
    {
      "cpu": 0,
      "environment": [],
      "essential": false,
      "firelensConfiguration": {
        "options": {
          "enable-ecs-log-metadata": "true"
        },
        "type": "fluentbit"
      },
      "image": "public.ecr.aws/aws-observability/aws-for-fluent-bit:stable",
      "memoryReservation": 51,
      "mountPoints": [],
      "name": "log_router",
      "portMappings": [],
      "systemControls": [],
      "user": "0",
      "volumesFrom": []
    },
    {
      "cpu": 0,
      "environment": [
        {
          "name": "ECS_FARGATE",
          "value": "true"
        },
        {
          "name": "DD_APM_ENABLED",
          "value": "true"
        },
        {
          "name": "DD_SITE",
          "value": "us5.datadoghq.com"
        },
        {
          "name": "DD_TAGS",
          "value": "service:mcp-server env:prod version:<IMAGE_TAG>"
        }
      ],
      "secrets": [
        {
          "name": "DD_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-west-1:891377126026:secret:datadog-api-key-N1eR8O"
        }
      ],
      "environmentFiles": [],
      "essential": false,
      "image": "891377126026.dkr.ecr.us-west-1.amazonaws.com/datadog/agent:7.70.0",
      "mountPoints": [],
      "name": "datadog-agent",
      "portMappings": [],
      "systemControls": [],
      "volumesFrom": []
    }
  ]
}
