# Cekura OpenAPI MCP Server Configuration

# OPTIONAL: Base URL of the Cekura API
# Default: https://api.cekura.ai (production)
# Uncomment to override (e.g., for staging/dev environments)
CEKURA_BASE_URL=https://backend.usesynth.co

# OPTIONAL: Filter tools by tags (comma-separated)
# Leave empty to use whitelist from documented_apis.json (recommended)
CEKURA_FILTER_TAGS=

# OPTIONAL: Exclude specific operations (comma-separated operation IDs)
# Leave empty to use whitelist from documented_apis.json (recommended)
CEKURA_EXCLUDE_OPERATIONS=

# OPTIONAL: Maximum number of tools to register (for testing only)
# Leave empty for no limit - whitelist determines registered tools
CEKURA_MAX_TOOLS=

# NOTE: API keys are REQUIRED via X-CEKURA-API-KEY header when connecting:
# claude mcp add cekura-api http://localhost:8001/mcp --transport http \
#   --header "X-CEKURA-API-KEY:your_api_key_here"

# ---- OAuth settings (required for Claude.ai web connector support) ----

# Secret for signing MCP JWTs (access tokens + refresh tokens + exchange codes).
# Must match MCP_JWT_SECRET set on the dashboard (vocera.frontend.product).
# Set a stable random string — if unset, a temporary secret is generated per
# restart and all issued tokens become invalid on the next restart.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_JWT_SECRET=

# Public URL of this MCP server — used in OAuth metadata so Claude.ai knows
# where to find /authorize, /token, etc.
# For local testing use http://localhost:8001
# For production: https://api.cekura.ai
MCP_ISSUER_URL=http://localhost:8001

# OPTIONAL: Allow clients to override the backend URL via X-CEKURA-BASE-URL header.
# NEVER enable in production — SSRF risk. For local dev/staging only.
ALLOW_BASE_URL_OVERRIDE=

# URL of the Cekura dashboard — OAuth login redirects here.
# Default: https://app.cekura.ai (production)
# Set to http://localhost:3000 if running the dashboard locally.
DASHBOARD_URL=https://app.cekura.ai
